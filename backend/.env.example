# ─────────────────────────────────────────────────────────────
# MOTORIQ API — environment configuration
# Copy to `.env` and fill in. The app runs with mock integrations
# out of the box; supply real credentials to go live.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# CORS — comma separated list of allowed origins (use * for dev)
CORS_ORIGINS=*

# Database (PostgreSQL). Business plan targets Azure; any Postgres works.
DATABASE_URL="postgresql://motoriq:motoriq@localhost:5432/motoriq?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Wallester (virtual cards + fuel wallets) ──
# Docs: https://api-doc.wallester.com
# Leave WALLESTER_MOCK=true to run without live credentials.
WALLESTER_MOCK=true
WALLESTER_BASE_URL=https://api.wallester.com
WALLESTER_API_VERSION=6.0
WALLESTER_AUDIENCE_ID=
WALLESTER_API_KEY=
# PEM-encoded RSA private key used to sign requests (single line, \n escaped)
WALLESTER_PRIVATE_KEY=
# Program/product identifiers issued to you by Wallester
WALLESTER_PROGRAM_ID=
WALLESTER_CARD_PRODUCT_ID=
WALLESTER_DEFAULT_CURRENCY=GBP

# ── UK fuel + EV price data ──
# mock      = bundled sample stations (no network)
# aggregate = pull the UK scheme's public per-retailer JSON feeds (REAL data, NO auth)
# single    = the official gov.uk Fuel Finder REST endpoint (OAuth 2.0)
FUEL_FINDER_MODE=mock
FUEL_FINDER_BASE_URL=https://api.fuel-finder.service.gov.uk
# ── single-mode auth: OAuth 2.0 client-credentials (the official API) ──
# Fuel Finder uses OAuth 2.0 client-credentials (test + production). The token
# endpoint returns a short-lived Bearer token; the client refreshes it as
# needed and sends `Authorization: Bearer <token>` on each request.
FUEL_FINDER_CLIENT_ID=
FUEL_FINDER_CLIENT_SECRET=
FUEL_FINDER_TOKEN_URL=
# Fuel Finder's documented scope:
FUEL_FINDER_SCOPE=fuelfinder.read
# Fuel Finder sends client_id/client_secret in the form body → 'post'.
FUEL_FINDER_AUTH_STYLE=post
# fallback only — if a provider ever issues a static bearer key instead of OAuth
FUEL_FINDER_API_KEY=
# Optional: comma-separated retailer feed URLs for aggregate mode.
# Leave blank to use the built-in UK CMA/Fuel Finder feed list.
FUEL_RETAILER_FEEDS=
FUEL_FEED_TTL_SECONDS=900
DEFAULT_TANK_LITRES=45

# ── AI savings insights (Claude) ──
# Optional. Without a key, the savings engine still computes all figures and
# returns a rule-based narrative. With a key, Claude generates a personalised
# summary + money-saving tips.
ANTHROPIC_API_KEY=
AI_INSIGHTS_MODEL=claude-opus-4-8

# ── Push notifications (Firebase Cloud Messaging) ──
# mock = log instead of sending. Set fcm + the service-account fields to send.
PUSH_PROVIDER=mock
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Service-account private key (PEM). Escape newlines as \n on one line.
FCM_PRIVATE_KEY=

# ── Admin/ops account (seeded by `npm run seed`, used for /admin dashboard) ──
ADMIN_EMAIL=admin@motoriq.co.uk
ADMIN_PASSWORD=admin12345
