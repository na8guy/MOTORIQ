// SaveOnDrive data model
// "The Smart Membership for Cheaper Driving"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Users & auth ───────────────────────────

enum Tier {
  FREE
  PREMIUM
  PRO
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  phone         String?
  tier          Tier    @default(FREE)
  role          Role    @default(USER)
  emailVerified Boolean @default(false)

  // ── Consent (UK GDPR) ──
  // Recorded per acceptance with the version accepted, because consent must be
  // demonstrable and re-obtained when the terms materially change. Marketing is
  // a separate opt-in: bundling it into "accept terms" is not freely given
  // consent under UK GDPR, so it must never default to true.
  termsAcceptedAt   DateTime?
  termsVersion      String?
  privacyAcceptedAt DateTime?
  privacyVersion    String?
  marketingOptIn    Boolean   @default(false)

  /**
   * Display units. UK drivers think in miles, so that's the default.
   */
  distanceUnit DistanceUnit @default(MILES)

  // ── Admin tier simulation ──
  // Lets an admin experience a paid tier without paying, to test what members
  // actually see. Deliberately a stored column rather than something inferred:
  // it appears in the audit log, survives a restart, and — because only an
  // ADMIN check ever sets it — a member cannot grant it to themselves.
  simulatedTier Tier?

  /**
   * Stripe customer id, so a member keeps one customer across subscriptions.
   */
  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles           Vehicle[]
  reminders          Reminder[]
  wallet             Wallet?
  cards              Card[]
  subscription       Subscription?
  savings            SavingsRecord[]
  refreshTokens      RefreshToken[]
  referralsMade      Referral[]          @relation("Referrer")
  kyc                KycProfile?
  riskEvents         RiskEvent[]
  fuelPurchases      FuelPurchase[]
  deviceTokens       DeviceToken[]
  notifications      Notification[]
  verificationTokens VerificationToken[]
  perkGrants         PerkGrant[]
  serviceBookings    ServiceBooking[]
  gloveboxDocuments  GloveboxDocument[]

  @@map("users")
}

enum TokenPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model VerificationToken {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * Stored as a SHA-256 hash — see auth token helpers for why.
   */
  token     String       @unique
  /**
   * One table, two jobs: a reset token must never verify an email, or vice versa.
   */
  purpose   TokenPurpose @default(EMAIL_VERIFY)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([userId])
  @@index([purpose])
  @@map("verification_tokens")
}

enum DistanceUnit {
  MILES
  KM
}

// ─────────────────────────── Push notifications ───────────────────────────

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

model DeviceToken {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String         @unique // FCM registration token
  platform  DevicePlatform @default(ANDROID)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@map("device_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   @default("GENERAL") // FUEL, KYC, WALLET, RISK, MARKETING…
  data      Json? // arbitrary deep-link payload
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────── Vehicles ───────────────────────────

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  PLUGIN_HYBRID
  LPG
}

model Vehicle {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  registration String
  make         String?
  model        String?
  year         Int?
  fuelType     FuelType @default(PETROL)
  mileage      Int?
  colour       String?

  // ── Auto-filled from government APIs (see integrations/dvla) ──
  // taxStatus/taxDueDate come from the DVLA Vehicle Enquiry Service.
  // motStatus/motExpiryDate come from the DVSA MOT History API — VES does NOT
  // publish an MOT expiry date, only a status, so they are two separate calls.
  taxStatus     String?
  taxDueDate    DateTime?
  motStatus     String?
  motExpiryDate DateTime?
  dvlaSyncedAt  DateTime?
  /**
   * Why the last sync failed (unregistered key, unknown VRN, …).
   */
  dvlaSyncError String?

  // ── Member-entered: no public API exists for these ──
  // Insurance renewal dates live in the Motor Insurance Database, which is
  // restricted to insurers/police — there is no public lookup. Service
  // intervals are per-manufacturer schedules, also not published as an API.
  insuranceRenewalDate DateTime?
  serviceDueDate       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminders Reminder[]

  @@unique([userId, registration])
  @@index([userId])
  @@map("vehicles")
}

// ─────────────────────────── Reminders ───────────────────────────

enum ReminderType {
  MOT
  ROAD_TAX
  SERVICE
  INSURANCE
  BREAKDOWN
  OTHER
}

model Reminder {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId  String?
  vehicle    Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  type       ReminderType
  dueDate    DateTime
  note       String?
  completed  Boolean      @default(false)
  /**
   * Last time we pinged the member — stops a re-run notifying twice a day.
   */
  notifiedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId])
  @@index([dueDate])
  @@map("reminders")
}

// ─────────────────────────── Wallet & cards ───────────────────────────

model Wallet {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Balance held in minor units (pence) to avoid float errors.
  balanceMinor       Int      @default(0)
  currency           String   @default("GBP")
  // External account reference at the card issuer (Wallester).
  wallesterAccountId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

enum TxnType {
  TOPUP
  SPEND
  REWARD
  REFUND
  SUBSCRIPTION
  ADJUSTMENT
}

enum TxnStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

model WalletTransaction {
  id          String    @id @default(cuid())
  walletId    String
  wallet      Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        TxnType
  status      TxnStatus @default(COMPLETED)
  amountMinor Int // signed: credits positive, debits negative
  currency    String    @default("GBP")
  description String?
  reference   String?   @unique // idempotency / external ref
  createdAt   DateTime  @default(now())

  @@index([walletId])
  @@map("wallet_transactions")
}

enum CardStatus {
  PENDING
  ACTIVE
  FROZEN
  CLOSED
}

model Card {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallesterCardId String?    @unique
  last4           String?
  brand           String     @default("Mastercard")
  status          CardStatus @default(PENDING)
  virtual         Boolean    @default(true)
  expiryMonth     Int?
  expiryYear      Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId])
  @@map("cards")
}

// ─────────────────────────── Subscriptions ───────────────────────────

enum SubPlan {
  FREE
  PREMIUM
  PRO
}

enum SubStatus {
  /// Paid and current.
  ACTIVE
  /// In a free trial.
  TRIALING
  /// Payment failed; Stripe is retrying. Access continues briefly by design —
  /// a card expiring should not instantly strip someone of breakdown cover.
  PAST_DUE
  /// Cancelled. Features last until currentPeriodEnd, which they paid for.
  CANCELLED
  /// Stripe gave up after retries, or the member was refunded.
  UNPAID
  /// Checkout started but never completed.
  INCOMPLETE
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
}

model Subscription {
  id     String    @id @default(cuid())
  userId String    @unique
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   SubPlan   @default(FREE)
  status SubStatus @default(ACTIVE)

  billingPeriod BillingPeriod @default(MONTHLY)
  priceMinor    Int           @default(0)

  // ── Stripe ──
  // Stripe is the source of truth for whether money arrived. These ids let a
  // webhook find the right row, and let us open the customer portal.
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  /// End of the paid period. A cancelled member keeps their features until
  /// this passes — they paid for that time.
  currentPeriodEnd  DateTime?
  /// Set when they cancel but the period has not yet ended.
  cancelAtPeriodEnd Boolean   @default(false)

  startedAt   DateTime  @default(now())
  renewsAt    DateTime?
  cancelledAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

/// Perks are per-period allowances (6 litres a month, 1 MOT a year). This is
/// the ledger that stops a member claiming January's litres twice.
model PerkGrant {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind   PerkKind
  /// The period this belongs to: "2026-07" monthly, "2026" annual.
  period String

  /// Allowance for the period (litres, or a count of services).
  allowance  Int
  /// How much has been claimed.
  claimed    Int @default(0)
  /// Cash value granted, in pence — what this perk actually cost us.
  valueMinor Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, kind, period])
  @@index([userId])
  @@map("perk_grants")
}

enum PerkKind {
  FUEL_LITRES
  SERVICE
  MOT
  BREAKDOWN
}

// ─────────────────────────── Savings & rewards ───────────────────────────

enum SavingsCategory {
  FUEL
  EV_CHARGING
  INSURANCE
  SERVICE
  MOT
  CASHBACK
  OTHER
}

model SavingsRecord {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    SavingsCategory
  amountMinor Int // amount saved, in pence
  description String?
  occurredAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@map("savings_records")
}

// ─────────────────────────── Referrals ───────────────────────────

enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
}

model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  referrer     User           @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  code         String         @unique
  refereeEmail String?
  status       ReferralStatus @default(PENDING)
  rewardMinor  Int            @default(1000) // Give £10 / Get £10
  createdAt    DateTime       @default(now())
  completedAt  DateTime?

  @@index([referrerId])
  @@map("referrals")
}

// ─────────────────────────── KYC / identity ───────────────────────────
// Because SaveOnDrive moves money (prepaid wallet + Mastercard), members must
// pass identity checks (KYC) before financial actions are enabled. The
// banking partner (Wallester) performs the regulated AML/KYC; we collect
// and mirror the verification state here.

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model KycProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          KycStatus @default(NOT_STARTED)
  riskLevel       RiskLevel @default(LOW)
  // Applicant data (store only what you need; encrypt/tokenise in production).
  dateOfBirth     DateTime?
  addressLine1    String?
  addressLine2    String?
  city            String?
  postcode        String?
  country         String    @default("GB")
  nationality     String?
  documentType    String? // PASSPORT | DRIVING_LICENCE | NATIONAL_ID
  documentNumber  String?
  // External applicant reference at the KYC/issuer provider.
  wallesterKycId  String?
  rejectionReason String?
  submittedAt     DateTime?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("kyc_profiles")
}

// ─────────────────────────── Fraud mitigation ───────────────────────────

enum RiskDecision {
  ALLOW
  REVIEW
  BLOCK
}

model RiskEvent {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String // e.g. TOPUP, SPEND, CARD_ISSUE, LOGIN
  decision    RiskDecision
  score       Int // 0 (safe) .. 100 (severe)
  reasons     String[] // list of triggered rules
  amountMinor Int?
  reference   String?
  ipAddress   String?
  deviceId    String?
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("risk_events")
}

// ─────────────────────────── Fuel purchases (AI savings engine) ───────────
// Captures real fill-ups so the savings engine can compute how much a
// member saved vs the local benchmark, and roll it up daily/weekly/monthly.

model FuelPurchase {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId             String?
  fuelKind              String // E10 | E5 | B7 | SDV | ELECTRIC
  litres                Float // (or kWh for ELECTRIC)
  pricePencePerUnit     Float // what the member actually paid
  totalMinor            Int // total spend in pence
  stationBrand          String?
  stationPostcode       String?
  latitude              Float?
  longitude             Float?
  // Benchmark the engine compared against (area average) and computed saving.
  benchmarkPencePerUnit Float?
  savedMinor            Int      @default(0)
  purchasedAt           DateTime @default(now())
  createdAt             DateTime @default(now())

  // ── Did this fill-up actually happen? ──
  // Tapping "Navigate here" only proves intent — the member may arrive and
  // change their mind, or pay elsewhere. Counting intent as savings would make
  // the headline number fiction, so a purchase only counts once CONFIRMED,
  // either by a matched card transaction or by the member saying so.
  status             PurchaseStatus @default(CONFIRMED)
  confirmationSource ConfirmSource?
  confirmedAt        DateTime?
  /**
   * A PENDING intent past this is swept to EXPIRED and never counted.
   */
  expiresAt          DateTime?
  /**
   * Station identity, so a card transaction can be matched back to the intent.
   */
  siteId             String?
  /**
   * Set when we've asked "did you fill up?", so we only ask once.
   */
  promptedAt         DateTime?

  @@index([userId])
  @@index([purchasedAt])
  @@index([status])
  @@map("fuel_purchases")
}

enum PurchaseStatus {
  /// Intent recorded (member tapped Navigate). Never counted toward savings.
  PENDING
  /// Proven by a card match, or the member confirmed. Counts.
  CONFIRMED
  /// Member said they didn't buy. Never counted.
  DECLINED
  /// Nobody confirmed in time. Never counted.
  EXPIRED
}

enum ConfirmSource {
  /// A Wallester card transaction matched this station — authoritative.
  CARD_MATCH
  /// The member answered "yes, I filled up".
  MEMBER
  /// Logged by hand, or imported.
  MANUAL
}

// ─────────────────────────── Service marketplace ───────────────────────────

/// A vetted garage or fitter we can book on a member's behalf.
///
/// Commission revenue is the point: the member gets one-tap booking, the
/// partner gets a customer, and we take a percentage. commissionBps is stored
/// per partner because it is negotiated per deal, not fixed.
model ServicePartner {
  id            String   @id @default(cuid())
  name          String
  /// MOT, SERVICE, TYRES, VALETING, REPAIR — a partner may offer several.
  services      String[]
  address       String
  postcode      String
  latitude      Float
  longitude     Float
  phone         String?
  /// 0–5, from our own vetting plus member feedback.
  rating        Float?
  ratingCount   Int      @default(0)
  /// Our cut, in basis points (250 = 2.5%).
  commissionBps Int      @default(1000)
  /// Vetted partners only are bookable. Unvetted ones are listed but not sold.
  vetted        Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings ServiceBooking[]

  @@index([postcode])
  @@map("service_partners")
}

enum BookingStatus {
  /// Member asked; the garage has not confirmed a slot.
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  /// The garage could not take it.
  DECLINED
}

model ServiceBooking {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId String?

  partnerId String
  partner   ServicePartner @relation(fields: [partnerId], references: [id])

  /// MOT | SERVICE | TYRES | VALETING | REPAIR
  serviceType String
  status      BookingStatus @default(REQUESTED)

  /// When the member wants it, and when the garage actually confirmed.
  requestedFor DateTime
  confirmedFor DateTime?

  quotedMinor      Int?
  paidMinor        Int?
  /// Our commission on this booking, once completed.
  commissionMinor  Int?
  /// Set when a membership perk covered some or all of it.
  perkAppliedMinor Int  @default(0)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([partnerId])
  @@index([status])
  @@map("service_bookings")
}

// ─────────────────────────── Vehicle health ───────────────────────────

/// A periodic assessment of a vehicle, generated from what we actually know:
/// MOT history and advisories, mileage, age, and reminder status. Deliberately
/// NOT a diagnosis — see vehicle-health.service.ts for what each score means.
model VehicleHealthReport {
  id        String @id @default(cuid())
  userId    String
  vehicleId String

  /// 0–100. Higher is healthier.
  score Int
  /// GOOD | ATTENTION | URGENT
  band  String

  /// The findings, each with a severity and a reason.
  findings Json
  /// What we suggest doing, most urgent first.
  actions  Json

  /// Estimated cost of the recommended work, in pence.
  estimatedCostMinor Int?

  generatedAt DateTime @default(now())

  @@index([userId])
  @@index([vehicleId])
  @@map("vehicle_health_reports")
}

// ─────────────────────────── Digital glovebox ───────────────────────────

/// Documents a member stores against a vehicle — MOT certificates, insurance,
/// service history. Files live in object storage; only metadata is here.
model GloveboxDocument {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId String?

  /// MOT | INSURANCE | SERVICE | V5C | WARRANTY | OTHER
  kind       String
  title      String
  /// Where the file actually lives. Never the file itself.
  storageKey String
  mimeType   String
  sizeBytes  Int
  /// Renewal/expiry, so the glovebox can feed reminders.
  expiresAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([vehicleId])
  @@map("glovebox_documents")
}
