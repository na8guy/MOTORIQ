// MOTORIQ data model
// "The Smart Membership for Cheaper Driving"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Users & auth ───────────────────────────

enum Tier {
  FREE
  PLUS
  DRIVE
  DRIVE_PLUS
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  phone         String?
  tier          Tier     @default(FREE)
  role          Role     @default(USER)
  emailVerified Boolean  @default(false)

  // ── Consent (UK GDPR) ──
  // Recorded per acceptance with the version accepted, because consent must be
  // demonstrable and re-obtained when the terms materially change. Marketing is
  // a separate opt-in: bundling it into "accept terms" is not freely given
  // consent under UK GDPR, so it must never default to true.
  termsAcceptedAt   DateTime?
  termsVersion      String?
  privacyAcceptedAt DateTime?
  privacyVersion    String?
  marketingOptIn    Boolean   @default(false)

  /** Display units. UK drivers think in miles, so that's the default. */
  distanceUnit DistanceUnit @default(MILES)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles      Vehicle[]
  reminders     Reminder[]
  wallet        Wallet?
  cards         Card[]
  subscription  Subscription?
  savings       SavingsRecord[]
  refreshTokens RefreshToken[]
  referralsMade Referral[]      @relation("Referrer")
  kyc                KycProfile?
  riskEvents         RiskEvent[]
  fuelPurchases      FuelPurchase[]
  deviceTokens       DeviceToken[]
  notifications      Notification[]
  verificationTokens VerificationToken[]

  @@map("users")
}

enum TokenPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model VerificationToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** Stored as a SHA-256 hash — see auth token helpers for why. */
  token  String @unique
  /** One table, two jobs: a reset token must never verify an email, or vice versa. */
  purpose   TokenPurpose @default(EMAIL_VERIFY)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([userId])
  @@index([purpose])
  @@map("verification_tokens")
}

enum DistanceUnit {
  MILES
  KM
}

// ─────────────────────────── Push notifications ───────────────────────────

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

model DeviceToken {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String         @unique // FCM registration token
  platform  DevicePlatform @default(ANDROID)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@map("device_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   @default("GENERAL") // FUEL, KYC, WALLET, RISK, MARKETING…
  data      Json? // arbitrary deep-link payload
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────── Vehicles ───────────────────────────

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  PLUGIN_HYBRID
  LPG
}

model Vehicle {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  registration String
  make         String?
  model        String?
  year         Int?
  fuelType     FuelType @default(PETROL)
  mileage      Int?
  colour       String?

  // ── Auto-filled from government APIs (see integrations/dvla) ──
  // taxStatus/taxDueDate come from the DVLA Vehicle Enquiry Service.
  // motStatus/motExpiryDate come from the DVSA MOT History API — VES does NOT
  // publish an MOT expiry date, only a status, so they are two separate calls.
  taxStatus     String?
  taxDueDate    DateTime?
  motStatus     String?
  motExpiryDate DateTime?
  dvlaSyncedAt  DateTime?
  /** Why the last sync failed (unregistered key, unknown VRN, …). */
  dvlaSyncError String?

  // ── Member-entered: no public API exists for these ──
  // Insurance renewal dates live in the Motor Insurance Database, which is
  // restricted to insurers/police — there is no public lookup. Service
  // intervals are per-manufacturer schedules, also not published as an API.
  insuranceRenewalDate DateTime?
  serviceDueDate       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminders Reminder[]

  @@unique([userId, registration])
  @@index([userId])
  @@map("vehicles")
}

// ─────────────────────────── Reminders ───────────────────────────

enum ReminderType {
  MOT
  ROAD_TAX
  SERVICE
  INSURANCE
  BREAKDOWN
  OTHER
}

model Reminder {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId String?
  vehicle   Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  type      ReminderType
  dueDate   DateTime
  note      String?
  completed Boolean      @default(false)
  /** Last time we pinged the member — stops a re-run notifying twice a day. */
  notifiedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
  @@index([dueDate])
  @@map("reminders")
}

// ─────────────────────────── Wallet & cards ───────────────────────────

model Wallet {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Balance held in minor units (pence) to avoid float errors.
  balanceMinor       Int      @default(0)
  currency           String   @default("GBP")
  // External account reference at the card issuer (Wallester).
  wallesterAccountId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

enum TxnType {
  TOPUP
  SPEND
  REWARD
  REFUND
  SUBSCRIPTION
  ADJUSTMENT
}

enum TxnStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

model WalletTransaction {
  id          String    @id @default(cuid())
  walletId    String
  wallet      Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        TxnType
  status      TxnStatus @default(COMPLETED)
  amountMinor Int // signed: credits positive, debits negative
  currency    String    @default("GBP")
  description String?
  reference   String?   @unique // idempotency / external ref
  createdAt   DateTime  @default(now())

  @@index([walletId])
  @@map("wallet_transactions")
}

enum CardStatus {
  PENDING
  ACTIVE
  FROZEN
  CLOSED
}

model Card {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallesterCardId String?    @unique
  last4           String?
  brand           String     @default("Mastercard")
  status          CardStatus @default(PENDING)
  virtual         Boolean    @default(true)
  expiryMonth     Int?
  expiryYear      Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId])
  @@map("cards")
}

// ─────────────────────────── Subscriptions ───────────────────────────

enum SubPlan {
  FREE
  PLUS
  DRIVE
  DRIVE_PLUS
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Subscription {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           SubPlan   @default(FREE)
  status         SubStatus @default(ACTIVE)
  // For DRIVE tiers: the monthly mileage package (500 / 1000 / 1500).
  mileagePackage Int?
  priceMinor     Int       @default(0) // monthly price in pence
  startedAt      DateTime  @default(now())
  renewsAt       DateTime?
  cancelledAt    DateTime?
  updatedAt      DateTime  @updatedAt

  @@map("subscriptions")
}

// ─────────────────────────── Savings & rewards ───────────────────────────

enum SavingsCategory {
  FUEL
  EV_CHARGING
  INSURANCE
  SERVICE
  MOT
  CASHBACK
  OTHER
}

model SavingsRecord {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    SavingsCategory
  amountMinor Int // amount saved, in pence
  description String?
  occurredAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@map("savings_records")
}

// ─────────────────────────── Referrals ───────────────────────────

enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
}

model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  referrer     User           @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  code         String         @unique
  refereeEmail String?
  status       ReferralStatus @default(PENDING)
  rewardMinor  Int            @default(1000) // Give £10 / Get £10
  createdAt    DateTime       @default(now())
  completedAt  DateTime?

  @@index([referrerId])
  @@map("referrals")
}

// ─────────────────────────── KYC / identity ───────────────────────────
// Because MOTORIQ moves money (prepaid wallet + Mastercard), members must
// pass identity checks (KYC) before financial actions are enabled. The
// banking partner (Wallester) performs the regulated AML/KYC; we collect
// and mirror the verification state here.

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model KycProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          KycStatus @default(NOT_STARTED)
  riskLevel       RiskLevel @default(LOW)
  // Applicant data (store only what you need; encrypt/tokenise in production).
  dateOfBirth     DateTime?
  addressLine1    String?
  addressLine2    String?
  city            String?
  postcode        String?
  country         String    @default("GB")
  nationality     String?
  documentType    String? // PASSPORT | DRIVING_LICENCE | NATIONAL_ID
  documentNumber  String?
  // External applicant reference at the KYC/issuer provider.
  wallesterKycId  String?
  rejectionReason String?
  submittedAt     DateTime?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("kyc_profiles")
}

// ─────────────────────────── Fraud mitigation ───────────────────────────

enum RiskDecision {
  ALLOW
  REVIEW
  BLOCK
}

model RiskEvent {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String // e.g. TOPUP, SPEND, CARD_ISSUE, LOGIN
  decision    RiskDecision
  score       Int // 0 (safe) .. 100 (severe)
  reasons     String[] // list of triggered rules
  amountMinor Int?
  reference   String?
  ipAddress   String?
  deviceId    String?
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("risk_events")
}

// ─────────────────────────── Fuel purchases (AI savings engine) ───────────
// Captures real fill-ups so the savings engine can compute how much a
// member saved vs the local benchmark, and roll it up daily/weekly/monthly.

model FuelPurchase {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId             String?
  fuelKind              String // E10 | E5 | B7 | SDV | ELECTRIC
  litres                Float // (or kWh for ELECTRIC)
  pricePencePerUnit     Float // what the member actually paid
  totalMinor            Int // total spend in pence
  stationBrand          String?
  stationPostcode       String?
  latitude              Float?
  longitude             Float?
  // Benchmark the engine compared against (area average) and computed saving.
  benchmarkPencePerUnit Float?
  savedMinor            Int      @default(0)
  purchasedAt           DateTime @default(now())
  createdAt             DateTime @default(now())

  // ── Did this fill-up actually happen? ──
  // Tapping "Navigate here" only proves intent — the member may arrive and
  // change their mind, or pay elsewhere. Counting intent as savings would make
  // the headline number fiction, so a purchase only counts once CONFIRMED,
  // either by a matched card transaction or by the member saying so.
  status             PurchaseStatus @default(CONFIRMED)
  confirmationSource ConfirmSource?
  confirmedAt        DateTime?
  /** A PENDING intent past this is swept to EXPIRED and never counted. */
  expiresAt          DateTime?
  /** Station identity, so a card transaction can be matched back to the intent. */
  siteId             String?
  /** Set when we've asked "did you fill up?", so we only ask once. */
  promptedAt         DateTime?

  @@index([userId])
  @@index([purchasedAt])
  @@index([status])
  @@map("fuel_purchases")
}

enum PurchaseStatus {
  /// Intent recorded (member tapped Navigate). Never counted toward savings.
  PENDING
  /// Proven by a card match, or the member confirmed. Counts.
  CONFIRMED
  /// Member said they didn't buy. Never counted.
  DECLINED
  /// Nobody confirmed in time. Never counted.
  EXPIRED
}

enum ConfirmSource {
  /// A Wallester card transaction matched this station — authoritative.
  CARD_MATCH
  /// The member answered "yes, I filled up".
  MEMBER
  /// Logged by hand, or imported.
  MANUAL
}
