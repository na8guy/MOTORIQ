{
  "name": "saveondrive-api",
  "version": "0.1.0",
  "private": true,
  "description": "MOTORIQ backend API — the smart membership for cheaper driving",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run check:margins && tsc -p tsconfig.json && npm run predeploy && npm run seed:partners",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "check:margins": "tsx src/modules/entitlements/margins.check.ts",
    "check:mot": "tsx src/integrations/dvla/mot.check.ts",
    "seed:partners": "tsx prisma/seed-partners.ts",
    "predeploy": "tsx prisma/pre-deploy.ts",
    "check:push": "tsx src/integrations/push/fcm.check.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/sensible": "^6.0.2",
    "@prisma/client": "^6.1.0",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "opening_hours": "^3.14.0",
    "pino": "^9.5.0",
    "stripe": "^22.3.2",
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
